<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="700.0" prefWidth="800.0" style="-fx-background-color: #E1C8F1;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="bd.edu.seu.supershopmanagementsystem.Shop.GoodsController">
   <children>
      <TableView fx:id="goodTable" layoutX="132.0" layoutY="125.0" onMouseClicked="#onTableClicked" prefHeight="287.0" prefWidth="513.0">
        <columns>
          <TableColumn fx:id="typeColumn" prefWidth="88.0" text="Type" />
          <TableColumn fx:id="nameColumn" prefWidth="115.0" text="Product Name" />
            <TableColumn fx:id="quantityColumn" prefWidth="70.0" text="Quantity" />
            <TableColumn fx:id="priceColumn" prefWidth="97.0" text="Price" />
            <TableColumn fx:id="dateColumn" prefWidth="141.0" text="Expire Date" />
        </columns>
      </TableView>
      <TextField fx:id="searchField" layoutX="132.0" layoutY="90.0" onKeyTyped="#searchOnKeyType" prefHeight="25.0" prefWidth="201.0" promptText="Search by name" />
      <ChoiceBox fx:id="typeChoiceBox" layoutX="359.0" layoutY="90.0" onInputMethodTextChanged="#selectedItem" prefWidth="150.0" />
      <Button layoutX="368.0" layoutY="434.0" mnemonicParsing="false" onAction="#backToShop" text="Back" />
   </children>
</AnchorPane>
