<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="700.0" prefWidth="800.0" style="-fx-background-color: #E1C8F1;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="bd.edu.seu.supershopmanagementsystem.Shop.ClothesController">
   <children>
      <TableView fx:id="clotheTable" layoutX="174.0" layoutY="141.0" onMouseClicked="#selectedItem" prefHeight="336.0" prefWidth="452.0">
        <columns>
          <TableColumn fx:id="typeColumn" prefWidth="75.0" text="Type" />
          <TableColumn fx:id="nameColumn" prefWidth="75.0" text="Name" />
            <TableColumn fx:id="sizeColumn" prefWidth="75.0" text="Size" />
            <TableColumn fx:id="quantityColumn" prefWidth="109.0" text="Quantity" />
            <TableColumn fx:id="priceColumn" prefWidth="117.0" text="Price" />
        </columns>
      </TableView>
      <ChoiceBox fx:id="typeChoiceBox" layoutX="174.0" layoutY="66.0" onInputMethodTextChanged="#choiceBoxSelected" prefWidth="150.0" />
      <TextField fx:id="searchField" layoutX="174.0" layoutY="109.0" onKeyTyped="#startSearching" prefHeight="25.0" prefWidth="452.0" promptText="Search with dress name or size" />
      <Button layoutX="380.0" layoutY="505.0" mnemonicParsing="false" onAction="#backToShop" text="Back" />
   </children>
</AnchorPane>
