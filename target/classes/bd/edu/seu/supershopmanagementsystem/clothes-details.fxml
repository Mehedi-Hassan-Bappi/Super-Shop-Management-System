      <Label layoutX="32.0" layoutY="240.0" text="Quantity">
         <font>
            <Font size="13.0" />
         </font>
      </Label>
      <Label fx:id="quantityLabel" layoutX="112.0" layoutY="241.0" prefHeight="17.0" prefWidth="77.0" />
      <Label layoutX="34.0" layoutY="268.0" text="Set Quantity">
         <font>
            <Font size="13.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
