<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="300.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="bd.edu.seu.supershopmanagementsystem.Shop.ClothesDetailsController">
   <children>
      <Label layoutX="32.0" layoutY="186.0" text="Name">
         <font>
            <Font size="13.0" />
         </font></Label>
      <Label fx:id="nameLabel" layoutX="111.0" layoutY="183.0" prefHeight="17.0" prefWidth="77.0" />
      <Label fx:id="typeLabel" layoutX="118.0" layoutY="155.0" prefHeight="19.0" prefWidth="67.0">
         <font>
            <Font name="System Bold Italic" size="13.0" />
         </font>
      </Label>
      <Label layoutX="32.0" layoutY="214.0" text="Price">
         <font>
            <Font size="13.0" />
         </font>
      </Label>
      <Label fx:id="priceLabel" layoutX="112.0" layoutY="211.0" prefHeight="17.0" prefWidth="77.0" />
      <Spinner fx:id="quantityField" layoutX="111.0" layoutY="265.0" />
