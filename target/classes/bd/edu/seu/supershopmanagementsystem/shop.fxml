      <Label layoutX="683.0" layoutY="21.0" onMouseClicked="#goBackToHome" text="&lt;&lt;Back To Home" textFill="#0845ff" underline="true" />
      <Pane layoutX="52.0" layoutY="227.0" onMouseClicked="#goToClothes" prefHeight="213.0" prefWidth="213.0" style="-fx-background-color: #FBE739;">
