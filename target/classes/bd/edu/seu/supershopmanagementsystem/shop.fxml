            <Label layoutX="39.0" layoutY="165.0" text="Clothes Section">
               <font>
                  <Font name="System Bold Italic" size="19.0" />
               </font>
            </Label>
            <ImageView fitHeight="133.0" fitWidth="139.0" layoutX="39.0" layoutY="14.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@Add%20Clothes.png" />
               </image>
            </ImageView>
         </children>
      </Pane>
      <Pane layoutX="296.0" layoutY="227.0" onMouseClicked="#goToGrocery" prefHeight="213.0" prefWidth="213.0" style="-fx-background-color: #000000;">
