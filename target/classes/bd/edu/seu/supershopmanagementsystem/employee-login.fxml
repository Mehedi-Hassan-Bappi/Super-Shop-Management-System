<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="bd.edu.seu.supershopmanagementsystem.Employee.EmployeeLoginController">
   <children>
      <AnchorPane prefHeight="700.0" prefWidth="383.0" style="-fx-background-color: #8C71FC;">
         <children>
            <Label alignment="CENTER" layoutX="90.0" layoutY="350.0" prefHeight="74.0" prefWidth="243.0" text="Employee Login PAGE" textFill="#f8ffc4">
               <font>
                  <Font name="HoboStd" size="23.0" />
               </font>
            </Label>
            <Label layoutX="94.0" layoutY="631.0" text="New Employee??" textFill="#f8ffc4">
               <font>
                  <Font name="System Bold Italic" size="15.0" />
               </font>
            </Label>
            <Label layoutX="218.0" layoutY="633.0" onMouseClicked="#goToEmployeeRegistration" text="Register here" textFill="#74ff90" underline="true">
               <font>
                  <Font name="System Bold Italic" size="12.0" />
               </font>
            </Label>
         </children>
      </AnchorPane>
      <PasswordField fx:id="passwordField" layoutX="507.0" layoutY="374.0">
         <font>
            <Font size="15.0" />
         </font>
      </PasswordField>
      <TextField fx:id="nameField" layoutX="507.0" layoutY="257.0">
         <font>
            <Font size="15.0" />
         </font>
      </TextField>
      <Label layoutX="507.0" layoutY="230.0" text="Employee Name:" textFill="RED">
         <font>
            <Font size="15.0" />
         </font>
      </Label>
      <Label layoutX="507.0" layoutY="346.0" text="Employee Password:" textFill="RED">
         <font>
            <Font size="15.0" />
         </font>
      </Label>
      <Button layoutX="572.0" layoutY="434.0" mnemonicParsing="false" onAction="#login" text="Login">
         <font>
            <Font size="14.0" />
         </font>
      </Button>
      <Label alignment="CENTER" layoutX="95.0" layoutY="245.0" prefHeight="74.0" prefWidth="213.0" text="Welcome" textFill="#f8ffc4">
         <font>
            <Font name="HoboStd" size="34.0" />
         </font>
      </Label>
      <Label alignment="CENTER" layoutX="95.0" layoutY="295.0" prefHeight="74.0" prefWidth="213.0" text="To" textFill="#f8ffc4">
         <font>
            <Font name="HoboStd" size="34.0" />
         </font>
      </Label>
      <Label layoutX="725.0" layoutY="29.0" onMouseClicked="#backToFirstScene" text="&lt;&lt;Back" textFill="#0d00ff" underline="true">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
