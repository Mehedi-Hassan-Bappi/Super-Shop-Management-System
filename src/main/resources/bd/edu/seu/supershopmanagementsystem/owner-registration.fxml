      </PasswordField>
      <Label layoutX="243.0" layoutY="503.0" text="Gender">
         <font>
            <Font size="15.0" />
         </font>
      </Label>
      <RadioButton layoutX="363.0" layoutY="505.0" mnemonicParsing="false" text="Male" textFill="RED">
