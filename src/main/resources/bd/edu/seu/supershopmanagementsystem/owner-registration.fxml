      <RadioButton layoutX="455.0" layoutY="505.0" mnemonicParsing="false" text="Female" textFill="RED" toggleGroup="$genderSelection">
         <font>
            <Font size="15.0" />
         </font>
      </RadioButton>
      <TextField fx:id="emailField" layoutX="360.0" layoutY="289.0" prefHeight="25.0" prefWidth="182.0">
         <font>
            <Font size="15.0" />
         </font>
      </TextField>
      <Label layoutX="244.0" layoutY="294.0" text="Email Address">
         <font>
            <Font size="15.0" />
         </font>
      </Label>
      <Button layoutX="360.0" layoutY="587.0" mnemonicParsing="false" onAction="#save" text="Save">
         <font>
            <Font size="15.0" />
         </font>
      </Button>
