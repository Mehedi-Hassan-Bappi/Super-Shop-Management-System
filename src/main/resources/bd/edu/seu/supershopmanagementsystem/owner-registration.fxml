         <font>
            <Font size="11.0" />
         </font>
      </Label>
      <Label fx:id="numberEmpty" layoutX="362.0" layoutY="214.0" prefHeight="16.0" prefWidth="125.0" textFill="RED">
         <font>
            <Font size="11.0" />
         </font>
      </Label>
      <Button layoutX="645.0" layoutY="227.0" mnemonicParsing="false" onAction="#uploadImage" text="Set Image" />
      <ImageView fx:id="imageView" fitHeight="150.0" fitWidth="176.0" layoutX="598.0" layoutY="63.0" pickOnBounds="true" preserveRatio="true" />
